# ════════════════════════════════════════════════
# PARINAMA — Environment Variables
# ALL FREE — No credit card needed
# ════════════════════════════════════════════════

# ── Groq API (FREE) ──────────────────────────
# Sign up: https://console.groq.com
# PRIMARY LLM — fastest inference, generous free tier
GROQ_API_KEY=your_groq_key_here

# ── Google Gemini API (FREE) ─────────────────
# Sign up: https://aistudio.google.com
# FALLBACK 1 — powerful, free tier available
GEMINI_API_KEY=your_gemini_key_here

# ── Ollama (LOCAL — no key needed) ───────────
# Install: https://ollama.com
# Run: ollama pull mistral
# FALLBACK 2 — runs entirely on your device
OLLAMA_BASE_URL=http://localhost:11434

# ── Application Settings ─────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=sqlite:///./parinama.db

# ── Security ─────────────────────────────────
SECRET_KEY=your_random_secret_key_here
RATE_LIMIT=10/hour

# ── Evolution Defaults ───────────────────────
MAX_GENERATIONS=7
SCORE_THRESHOLD=90
REQUEST_TIMEOUT=30
